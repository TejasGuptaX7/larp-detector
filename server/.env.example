# Copy to .env and fill in. Never commit .env.
CURSOR_API_KEY=your-cursor-api-key
PORT=8787
# Optional: pin a model id. Defaults to "auto". e.g. composer-2.5
LARP_MODEL=auto

# Realtime transcription. Free $50 credit, no card: https://www.assemblyai.com
# With this set, the browser streams to AssemblyAI (fast + accurate). Without it,
# the app falls back to slower in-browser transcription.
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
